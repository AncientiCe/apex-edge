{
  "id": null,
  "uid": "apex-edge-dependencies",
  "title": "Dependencies & Data Flows",
  "tags": ["apex-edge", "dependencies"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "DB Operation Error Rate (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_db_operations_total{outcome=\"error\"}[5m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "DB Latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(apex_edge_db_operation_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbox Dispatch Attempts by Outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_outbox_dispatch_attempts_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox DLQ Growth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(apex_edge_outbox_dlq_total[15m]))",
          "legendFormat": "dlq increments"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Outbox Dispatcher Cycles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_outbox_dispatcher_cycles_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sync Ingest Batches by Entity/Outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_sync_ingest_batches_total[5m])) by (entity, outcome)",
          "legendFormat": "{{entity}} {{outcome}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Sync Ingest Latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, entity) (rate(apex_edge_sync_ingest_duration_seconds_bucket[5m])))",
          "legendFormat": "{{entity}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
