{
  "id": null,
  "uid": "apex-edge-system-health",
  "title": "Edge System Health",
  "tags": ["apex-edge", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Throughput (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 4xx/5xx Rate (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_http_requests_total{status_class=\"4xx\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(apex_edge_http_requests_total{status_class=\"5xx\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Latency p95/p99 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(apex_edge_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apex_edge_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "In-Flight Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(apex_edge_http_requests_in_flight)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Health/Ready Route Availability",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_http_requests_total{route=~\"health|ready\",status_class=\"2xx\"}[5m])) by (route)",
          "legendFormat": "{{route}} 2xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(apex_edge_http_requests_total{route=~\"health|ready\",status_class=\"5xx\"}[5m])) by (route)",
          "legendFormat": "{{route}} 5xx"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Auth Outcomes (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apex_edge_auth_requests_total[5m])) by (operation, outcome)",
          "legendFormat": "{{operation}} {{outcome}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
